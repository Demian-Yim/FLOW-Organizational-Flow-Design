rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: inquiries
    // Document ID: auto-generated
    // Fields:
    //   - company: string (required)
    //   - name: string (required)
    //   - contact: string (required)
    //   - email: string (optional)
    //   - course: string (optional)
    //   - schedule: string (optional)
    //   - target: string (optional)
    //   - location: string (optional)
    //   - issues: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: diagnostics
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - company: string (required)
    //   - email: string (required)
    //   - phone: string (required)
    //   - answers: map (required)
    //   - score: number (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "rescuemyself@gmail.com";
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidInquiry() {
      return hasRequiredFields(['company', 'name', 'contact', 'createdAt']) &&
             validStringLength('company', 1, 100) &&
             validStringLength('name', 1, 100) &&
             validStringLength('contact', 1, 100) &&
             isValidOptionalString('email', 0, 100) &&
             isValidOptionalString('course', 0, 100) &&
             isValidOptionalString('schedule', 0, 100) &&
             isValidOptionalString('target', 0, 100) &&
             isValidOptionalString('location', 0, 100) &&
             isValidOptionalString('issues', 0, 2000) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidDiagnostic() {
      return hasRequiredFields(['name', 'company', 'email', 'phone', 'answers', 'score', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             validStringLength('company', 1, 100) &&
             validStringLength('email', 1, 100) &&
             validStringLength('phone', 1, 100) &&
             request.resource.data.answers is map &&
             request.resource.data.score is number &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /inquiries/{inquiryId} {
      // Anyone can create an inquiry
      allow create: if isValidInquiry();
      // Only admin can read, update, or delete
      allow read, update, delete: if isAdmin();
    }

    match /diagnostics/{diagnosticId} {
      // Anyone can create a diagnostic
      allow create: if isValidDiagnostic();
      // Only admin can read, update, or delete
      allow read, update, delete: if isAdmin();
    }
  }
}
